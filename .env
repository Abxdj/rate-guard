PORT=3000
REDIS_URL=redis://localhost:6379

# Algorithm: token_bucket | sliding_window | leaky_bucket
ALGORITHM=token_bucket

# Token bucket config
TOKEN_BUCKET_CAPACITY=10
TOKEN_BUCKET_REFILL_RATE=5        # tokens per second

# Sliding window config
SLIDING_WINDOW_LIMIT=20
SLIDING_WINDOW_SIZE_MS=60000      # 1 minute

# Leaky bucket config
LEAKY_BUCKET_CAPACITY=10
LEAKY_BUCKET_DRAIN_RATE=2         # requests per second
